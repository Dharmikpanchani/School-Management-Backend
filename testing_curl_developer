curl -X POST {{URL}}/api/developer/add-update-sales \
  -H "Content-Type: application/json" \
  -H "Authorization: Bearer {{TOKEN}}" \
  -d '{
    "id": "SALES_OBJECT_ID",
    "email": "sales_updated@example.com",
    "number": "9988776655",
    "upiId": "sales_updated@upi"
  }'

# 23. GET ALL SALES (with populated school data)
curl -X GET {{URL}}/api/developer/get-all-sales \
  -H "Authorization: Bearer {{TOKEN}}"

# 24. GET SALES BY ID (with populated school data)
curl -X GET {{URL}}/api/developer/get-sales/SALES_OBJECT_ID \
  -H "Authorization: Bearer {{TOKEN}}"

