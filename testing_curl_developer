
# ============================================================
# BASE URL   : {{URL}}
# PREFIX     : /api/developer
# ============================================================

# -------------------------------------------------------
# FLOW 1: CREATE NEW ADMIN & OTP VERIFICATION
# (An existing admin logs in, creates a new admin. The new admin receives an OTP and verifies it.)
# -------------------------------------------------------

# 1a. LOGIN (Existing admin logs in to get an access token or OTP)
curl -X POST {{URL}}/api/developer/login \
  -H "Content-Type: application/json" \
  -d '{"email":"developer@example.com","password":"Password@123"}'

# 1b. VERIFY LOGIN OTP (If the above step returns { requireOtp: true })
curl -X POST {{URL}}/api/developer/verify-login-otp \
  -H "Content-Type: application/json" \
  -d '{"email":"developer@example.com","otp":"123456"}'

# 2. ADD / CREATE DEVELOPER ADMIN (Requires Auth)
# This will send a Registration OTP to the newly created admin's email.
curl -X POST {{URL}}/api/developer/add-edit-admin \
  -H "Content-Type: application/json" \
  -H "Authorization: Bearer {{TOKEN}}" \
  -d '{
    "name": "New Admin Name",
    "email": "new_admin@example.com",
    "password": "Password@123",
    "schoolId": "SCHOOL_OBJECT_ID",
    "role": "ROLE_OBJECT_ID",
    "address": "Surat"
  }'

# 3. VERIFY REGISTRATION OTP (The new admin verifies their account)
curl -X POST {{URL}}/api/developer/verify-registration-otp \
  -H "Content-Type: application/json" \
  -d '{"email":"new_admin@example.com","otp":"123456"}'

# 4. RESEND REGISTRATION OTP (If the new admin did not receive it)
curl -X POST {{URL}}/api/developer/re-send-otp \
  -H "Content-Type: application/json" \
  -d '{"email":"new_admin@example.com"}'


# -------------------------------------------------------
# FLOW 2: NEW ADMIN LOGIN & PROFILE MANAGEMENT
# -------------------------------------------------------

# 5a. LOGIN (New admin logs in after registration verification)
curl -X POST {{URL}}/api/developer/login \
  -H "Content-Type: application/json" \
  -d '{"email":"new_admin@example.com","password":"Password@123"}'

# 5b. VERIFY LOGIN OTP (If the new admin is configured as a SuperDeveloper)
curl -X POST {{URL}}/api/developer/verify-login-otp \
  -H "Content-Type: application/json" \
  -d '{"email":"new_admin@example.com","otp":"123456"}'

# 6. GET PROFILE (Requires Auth)
curl -X GET {{URL}}/api/developer/profile \
  -H "Authorization: Bearer {{TOKEN}}"

# 7. UPDATE PROFILE (Requires Auth, supports multipart for image upload)
curl -X PATCH {{URL}}/api/developer/update-profile \
  -H "Authorization: Bearer {{TOKEN}}" \
  -F "name=Developer Name" \
  -F "email=new_admin@example.com" \
  -F "phoneNumber=9876543210" \
  -F "address=Surat, Gujarat" \
  -F "imageUrl=@/path/to/profile.jpg"

# 8. REFRESH TOKEN (Uses HttpOnly cookie set at login)
curl -X POST {{URL}}/api/developer/refresh-token \
  --cookie "refreshToken=YOUR_REFRESH_TOKEN"

# 9. LOGOUT
curl -X POST {{URL}}/api/developer/logout \
  --cookie "refreshToken=YOUR_REFRESH_TOKEN"


# -------------------------------------------------------
# FLOW 3: FORGOT & CHANGE PASSWORD
# -------------------------------------------------------

# 10. FORGOT PASSWORD (Sends OTP to email)
curl -X POST {{URL}}/api/developer/forgot-password \
  -H "Content-Type: application/json" \
  -d '{"email":"new_admin@example.com"}'

# 11. VERIFY FORGOT PASSWORD OTP
curl -X POST {{URL}}/api/developer/verify-otp \
  -H "Content-Type: application/json" \
  -d '{"email":"new_admin@example.com","otp":"123456"}'

# 12. RESEND FORGOT PASSWORD OTP
curl -X POST {{URL}}/api/developer/resend-forgot-otp \
  -H "Content-Type: application/json" \
  -d '{"email":"new_admin@example.com"}'

# 13. RESET PASSWORD (After OTP verification is successful)
curl -X POST {{URL}}/api/developer/reset-password \
  -H "Content-Type: application/json" \
  -d '{"email":"new_admin@example.com","newPassword":"NewPassword@123","confirmPassword":"NewPassword@123"}'

# 14. CHANGE PASSWORD (Requires Auth from logged in user)
curl -X POST {{URL}}/api/developer/change-password \
  -H "Content-Type: application/json" \
  -H "Authorization: Bearer {{TOKEN}}" \
  -d '{"oldPassword":"Password@123","newPassword":"NewPassword@123","confirmPassword":"NewPassword@123"}'


# -------------------------------------------------------
# FLOW 4: ADMIN LISTING & MANAGEMENT
# -------------------------------------------------------

# 15. EDIT EXISTING ADMIN (Requires Auth)
curl -X POST {{URL}}/api/developer/add-edit-admin \
  -H "Content-Type: application/json" \
  -H "Authorization: Bearer {{TOKEN}}" \
  -d '{
    "id": "ADMIN_OBJECT_ID",
    "name": "Updated Admin Name",
    "email": "admin_updated@school.com",
    "schoolId": "SCHOOL_OBJECT_ID"
  }'

# 16. GET ALL ADMINS (Requires Auth, supports pagination & search)
curl -X GET "{{URL}}/api/developer/get-all-admins?pageNumber=1&perPageData=10&searchRequest=admin" \
  -H "Authorization: Bearer {{TOKEN}}"

# 17. TOGGLE ADMIN STATUS (Active/Inactive)
curl -X POST {{URL}}/api/developer/admin-action-status/ADMIN_OBJECT_ID \
  -H "Authorization: Bearer {{TOKEN}}"

# 18. DELETE ADMIN (Soft Delete)
curl -X DELETE {{URL}}/api/developer/delete-admin/ADMIN_OBJECT_ID \
  -H "Authorization: Bearer {{TOKEN}}"


# -------------------------------------------------------
# FLOW 5: ROLE MANAGEMENT
# -------------------------------------------------------

# 19. ADD NEW ROLE
curl -X POST {{URL}}/api/developer/add-edit-role \
  -H "Content-Type: application/json" \
  -H "Authorization: Bearer {{TOKEN}}" \
  -d '{
    "role": "manager",
    "permissions": ["admin_users.create", "admin_users.read", "roles.read"]
  }'

# 20. EDIT EXISTING ROLE
curl -X POST {{URL}}/api/developer/add-edit-role \
  -H "Content-Type: application/json" \
  -H "Authorization: Bearer {{TOKEN}}" \
  -d '{
    "id": "ROLE_OBJECT_ID",
    "role": "senior_manager",
    "permissions": ["admin_users.create", "admin_users.read", "admin_users.delete", "roles.read"]
  }'

# 21. GET ALL ROLES (supports pagination & search)
curl -X GET "{{URL}}/api/developer/get-all-roles?pageNumber=1&perPageData=10&searchRequest=manager" \
  -H "Authorization: Bearer {{TOKEN}}"

# 22. GET ROLE BY ID
curl -X GET {{URL}}/api/developer/get-role/ROLE_OBJECT_ID \
  -H "Authorization: Bearer {{TOKEN}}"

# 23. TOGGLE ROLE STATUS (Active/Inactive)
curl -X POST {{URL}}/api/developer/role-action-status/ROLE_OBJECT_ID \
  -H "Authorization: Bearer {{TOKEN}}"

# 24. DELETE ROLE (Soft Delete)
curl -X DELETE {{URL}}/api/developer/delete-role/ROLE_OBJECT_ID \
  -H "Authorization: Bearer {{TOKEN}}"


# -------------------------------------------------------
# FLOW 6: SALES MANAGEMENT
# -------------------------------------------------------

# 25. CREATE NEW SALES PROFILE
curl -X POST {{URL}}/api/developer/add-update-sales \
  -H "Content-Type: application/json" \
  -H "Authorization: Bearer {{TOKEN}}" \
  -d '{
    "email": "sales@example.com",
    "number": "9876543210",
    "upiId": "sales@upi"
  }'

# 26. UPDATE EXISTING SALES PROFILE
curl -X POST {{URL}}/api/developer/add-update-sales \
  -H "Content-Type: application/json" \
  -H "Authorization: Bearer {{TOKEN}}" \
  -d '{
    "id": "SALES_OBJECT_ID",
    "email": "sales_updated@example.com",
    "number": "9988776655",
    "upiId": "sales_updated@upi"
  }'

# 27. GET ALL SALES
curl -X GET {{URL}}/api/developer/get-all-sales \
  -H "Authorization: Bearer {{TOKEN}}"

# 28. GET SALES BY ID
curl -X GET {{URL}}/api/developer/get-sales/SALES_OBJECT_ID \
  -H "Authorization: Bearer {{TOKEN}}"

# 29. DELETE SALES
curl -X DELETE {{URL}}/api/developer/delete-sales/SALES_OBJECT_ID \
  -H "Authorization: Bearer {{TOKEN}}"
