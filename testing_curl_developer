curl -X POST {{URL}}/api/developer/add-update-sales \
  -H "Content-Type: application/json" \
  -H "Authorization: Bearer {{TOKEN}}" \
  -d '{
    "email": "sales@example.com",
    "number": "9876543210",
    "upiId": "sales@upi"
  }'

