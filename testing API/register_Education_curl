
# Get All Roles (Supports Pagination and Searching)
curl -X GET "http://localhost:YOUR_PORT/api/admin/get-all-roles?pageNumber=1&perPageData=10" \
  -H "Authorization: Bearer YOUR_ACCESS_TOKEN"

# Get Role By ID (Substitute ROLE_ID)
curl -X GET http://localhost:YOUR_PORT/api/admin/get-role/ROLE_ID \
  -H "Authorization: Bearer YOUR_ACCESS_TOKEN"

# Delete Role By ID (Substitute ROLE_ID)
curl -X DELETE http://localhost:YOUR_PORT/api/admin/delete-role/ROLE_ID \
  -H "Authorization: Bearer YOUR_ACCESS_TOKEN"

# Change Role Active/Inactive Status (Substitute ROLE_ID)
curl -X POST http://localhost:YOUR_PORT/api/admin/role-action-status/ROLE_ID \
  -H "Authorization: Bearer YOUR_ACCESS_TOKEN"